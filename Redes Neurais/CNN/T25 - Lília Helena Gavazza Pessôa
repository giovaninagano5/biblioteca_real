    "def evaluate_model(model, loader):\n",
    "\n",
    "    model.eval()\n",
    "\n",
    "    y_true = []\n",
    "    y_pred = []\n",
    "\n",
    "    with torch.no_grad():\n",
    "\n",
    "        for images, labels in loader:\n",
    "\n",
    "            images = images.to(device)\n",
    "\n",
    "            outputs = model(images)\n",
    "\n",
    "            _, predicted = torch.max(\n",
    "                outputs,\n",
    "                1\n",
    "            )\n",
    "\n",
    "            y_true.extend(\n",
    "                labels.numpy()\n",
    "            )\n",
    "\n",
    "            y_pred.extend(\n",
    "                predicted.cpu().numpy()\n",
    "            )\n",
    "\n",
    "    return y_true, y_pred"
   ]
