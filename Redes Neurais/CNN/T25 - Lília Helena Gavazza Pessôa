    "\n",
    "    transforms.RandomAffine(\n",
    "        degrees=0,\n",
    "        translate=(0.05,0.05) #translação de até 5% em x e y\n",
    "    ),\n",
    "\n",
    "    transforms.ToTensor(),\n",
    "])"
   ]
